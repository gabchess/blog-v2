{
  "name": "my-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "pnpm install && pnpm build",
    "dev": "dotenv -- turbo dev",
    "build": "dotenv -- turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:db": "./scripts/test.sh",
    "test:e2e": "turbo test:e2e",
    "test:all": "turbo test:all",
    "clean": "turbo clean && rm -rf .turbo",
    "clean:all": "turbo clean && rm -rf node_modules .turbo",
    "db:up": "docker compose up -d mongodb",
    "db:up:pg": "docker compose up -d postgres",
    "db:up:all": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d mongodb",
    "db:reset:pg": "docker compose down -v && docker compose up -d postgres",
    "db:push": "dotenv -- turbo run db:push --filter=@octant/db",
    "db:push:pg": "dotenv -- turbo run db:push --filter=@octant/db-postgres",
    "db:generate": "dotenv -- turbo run db:generate --filter=@octant/db",
    "db:generate:pg": "dotenv -- turbo run db:generate --filter=@octant/db-postgres",
    "db:studio": "pnpm --filter @octant/db db:studio",
    "db:studio:pg": "pnpm --filter @octant/db-postgres db:studio",
    "stop": "./scripts/stop.sh",
    "chain:dev": "pnpm --filter @octant/chain dev",
    "chain:staging": "dotenv -e .env.staging -- pnpm --filter @octant/chain staging",
    "chain:seed": "pnpm --filter @octant/chain seed:address",
    "subgraph:dev": "pnpm --filter @octant/subgraph dev",
    "subgraph:up": "docker compose -f apps/subgraph/docker-compose.yml up -d",
    "subgraph:down": "docker compose -f apps/subgraph/docker-compose.yml down",
    "dev:web": "dotenv -- turbo dev --filter @octant/chain --filter @octant/subgraph --filter @octant/web",
    "staging": "dotenv -e .env.staging -- turbo dev --filter @octant/subgraph --filter @octant/web",
    "dev:watch": "turbowatch ./turbowatch.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "conventional-recommended-bump": "^11.2.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "release-it": "^19.2.4",
    "semver": "^7.7.2",
    "turbo": "^2.3.3",
    "turbowatch": "^2.30.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
