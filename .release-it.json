{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "plugins": {
    "./.release-it-custom-version.mjs": {}
  },
  "git": {
    "changelog": "echo -n ''",
    "commitMessage": "chore(release): ${version} [skip ci]",
    "tagName": "${version}",
    "tagAnnotation": "Release ${version}",
    "push": true,
    "pushArgs": ["--follow-tags"],
    "requireBranch": false,
    "commit": true,
    "tag": true
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": true,
    "releaseName": "Release ${version}",
    "releaseNotes": "git-cliff --tag ${version} --config .cliff.toml -- $CHANGELOG_FROM..HEAD",
    "autoGenerate": false
  },
  "hooks": {
    "before:init": "git fetch --all --tags",
    "after:bump": "git-cliff --tag ${version} --prepend CHANGELOG.md --config .cliff.toml -- $CHANGELOG_FROM..HEAD"
  }
}
