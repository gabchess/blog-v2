{
  "name": "@octant/trpc",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "typecheck": "tsc --build",
    "test": "vitest run --exclude '**/*.e2e.test.ts'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@octant/db": "workspace:*",
    "@octant/validation": "workspace:*",
    "@trpc-limiter/memory": "^1.0.0",
    "@trpc/server": "^11.0.0-rc.682",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@trpc/client": "^11.0.0-rc.682",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
