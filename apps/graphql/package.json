{
  "name": "@octant/graphql",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "typecheck": "tsc --build",
    "test": "vitest run --exclude '**/*.e2e.test.ts'",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@escape.tech/graphql-armor": "^3.2.0",
    "@graphql-yoga/plugin-disable-introspection": "^2.19.0",
    "@octant/db": "workspace:*",
    "@octant/validation": "workspace:*",
    "@pothos/core": "^4.3.0",
    "@pothos/plugin-prisma": "^4.3.0",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@whatwg-node/server-plugin-cookies": "^1.0.5",
    "bcrypt": "^6.0.0",
    "graphql": "^16.9.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-query-complexity": "^1.1.0",
    "graphql-yoga": "^5.10.6",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.2.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/pino": "^7.0.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
