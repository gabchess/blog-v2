---
import "../styles/globals.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Octant Blog: infrastructure for onchain public goods funding.",
  ogImage = "/og-default.png",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

  </head>
  <body>
    <header style="border-bottom: 1px solid var(--color-light-grey-1); padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between;">
      <a href="/" style="font-weight: 700; font-size: 1.125rem; color: var(--color-ink); text-decoration: none;">
        Octant
      </a>
      <nav>
        <a href="/" style="margin-left: 1.5rem; color: var(--color-ink);">Blog</a>
      </nav>
    </header>

    <main style="max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem;">
      <slot />
    </main>

    <footer style="border-top: 1px solid var(--color-light-grey-1); padding: 2rem; text-align: center; color: var(--color-mid-grey); font-size: 0.875rem;">
      &copy; {year} Octant. Powered by Gitcoin.
    </footer>
  </body>
</html>
