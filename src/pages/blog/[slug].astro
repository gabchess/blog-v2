---
import Base from "../../layouts/Base.astro";
import { sanityClient } from "../../lib/sanity";
import { allPostsQuery, singlePostQuery } from "../../lib/queries";
import { PortableText } from "astro-portabletext";

interface PostListing {
  _id: string;
  slug: { current: string };
}

interface Post {
  _id: string;
  title: string;
  slug: { current: string };
  publishedAt: string;
  excerpt?: string;
  body: unknown[];
}

// Static mode: prerender every published post at build time.
// Sanity webhook to Vercel deploy hook triggers a fresh build on publish.
export async function getStaticPaths() {
  const posts = await sanityClient.fetch<PostListing[]>(allPostsQuery);
  return posts.map((post) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
const post = await sanityClient.fetch<Post | null>(singlePostQuery, { slug });

if (!post) {
  return Astro.redirect("/404");
}

const formattedDate = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
---

<Base title={post.title} description={post.excerpt}>
  <article>
    <header style="margin-bottom: 2rem;">
      <h1
        style="font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--color-ink); line-height: 1.25; margin-bottom: 0.5rem;"
      >
        {post.title}
      </h1>
      {
        formattedDate && (
          <time
            datetime={post.publishedAt}
            style="font-size: 0.875rem; color: var(--color-mid-grey);"
          >
            {formattedDate}
          </time>
        )
      }
    </header>

    <div
      style="font-size: 1.0625rem; line-height: 1.75; color: var(--color-ink);"
    >
      <PortableText value={post.body} />
    </div>
  </article>

  <aside
    style="margin-top: 4rem; padding: 2rem; background: var(--color-off-white-1); border-radius: 4px;"
  >
    <h2
      style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.75rem; color: var(--color-ink);"
    >
      Stay in the loop
    </h2>
    <p style="color: var(--color-mid-grey); margin-bottom: 1rem; font-size: 0.9375rem;">
      New posts on Octant research, epoch recaps, and ecosystem news. Subscribe on Substack.
    </p>
    <a
      href="https://octant.substack.com/"
      target="_blank"
      rel="noopener noreferrer"
      style="display: inline-block; padding: 0.625rem 1.25rem; background: var(--color-teal); color: #fff; text-decoration: none; border-radius: 3px; font-weight: 600; font-family: var(--font-body);"
    >
      Subscribe on Substack
    </a>
  </aside>
</Base>
