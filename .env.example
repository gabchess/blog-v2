# ─────────────────────────────────────────────────────────────────────────────
# Environment Variable Reference
# ─────────────────────────────────────────────────────────────────────────────
#
# TWO-FILE MODEL — each file is self-contained (no cascading, no composition)
#
#   .env           Everything dev needs    → loaded by: dotenv -- turbo dev
#   .env.staging   Everything staging needs → loaded by: dotenv -e .env.staging -- turbo dev
#
#   No app-specific env files (no apps/web/.env.local, no apps/rest/.env, etc.)
#
# HOW ENV VARS GET LOADED
#
#   Root scripts (pnpm dev, pnpm build, pnpm staging, etc.) use dotenv-cli:
#
#     "dev":     "dotenv -- turbo dev"              ← loads .env
#     "staging": "dotenv -e .env.staging -- turbo dev ..."  ← loads .env.staging
#
#   dotenv-cli injects vars into the shell's process.env BEFORE turbo runs.
#   Turbo inherits all env vars and passes them to every child process.
#   Turbo does NOT filter env vars — the `env` arrays in turbo.json control
#   cache key computation, not variable visibility.
#
# ─────────────────────────────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# DATABASES
# ═════════════════════════════════════════════════════════════════════════════
# Consumed by: Prisma (packages/db, packages/db-postgres)
# Loaded via:  dotenv-cli → turbo → tsx (backend apps import Prisma client)
# Required by: pnpm dev (all services), pnpm db:push, pnpm db:generate

# MongoDB — used by GraphQL API (apps/graphql) and tRPC API (apps/trpc)
DATABASE_URL=mongodb://localhost:27017/octant?replicaSet=rs0

# PostgreSQL — used by REST API (apps/rest)
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/octant


# ═════════════════════════════════════════════════════════════════════════════
# INFRASTRUCTURE PORTS
# ═════════════════════════════════════════════════════════════════════════════
# Host-side ports for Docker containers and local services.
# These control the port mapping on YOUR machine (not inside containers).
# Consumed by: docker-compose.yml, shell scripts, vite proxy targets

# MongoDB host port (container always listens on 27017 internally)
MONGODB_PORT=27017

# PostgreSQL host port (container always listens on 5432 internally)
POSTGRES_PORT=5432

# Anvil (local Ethereum node) port
ANVIL_PORT=8545


# ═════════════════════════════════════════════════════════════════════════════
# GRAPH NODE PORTS
# ═════════════════════════════════════════════════════════════════════════════
# Host-side ports for The Graph's infrastructure (apps/subgraph/docker-compose.yml)
# Consumed by: apps/subgraph/docker-compose.yml, apps/subgraph/scripts/dev.sh

# Graph Node GraphQL HTTP endpoint
GRAPH_NODE_HTTP_PORT=8000

# Graph Node GraphQL WebSocket endpoint
GRAPH_NODE_WS_PORT=8001

# Graph Node JSON-RPC admin endpoint
GRAPH_NODE_ADMIN_PORT=8020

# Graph Node index status endpoint
GRAPH_NODE_STATUS_PORT=8030

# IPFS node port
GRAPH_IPFS_PORT=5001

# Graph Node's internal PostgreSQL (separate from app PostgreSQL)
GRAPH_POSTGRES_PORT=5433


# ═════════════════════════════════════════════════════════════════════════════
# BACKEND API PORTS
# ═════════════════════════════════════════════════════════════════════════════
# Consumed by: respective app's src/index.ts, vite proxy targets, CORS defaults

# REST API (apps/rest)
REST_PORT=4000

# GraphQL API (apps/graphql)
GRAPHQL_PORT=4001

# tRPC API (apps/trpc)
TRPC_PORT=4002


# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND PORTS
# ═════════════════════════════════════════════════════════════════════════════
# Consumed by: respective app's vite.config.ts (server.port)

# Web app (apps/web)
WEB_PORT=3000

# Admin dashboard (apps/admin)
ADMIN_PORT=3001

# Widget demo (apps/widget)
WIDGET_PORT=3002

# QF Simulator (apps/qf-simulator)
QF_SIMULATOR_PORT=3003


# ═════════════════════════════════════════════════════════════════════════════
# AUTH
# ═════════════════════════════════════════════════════════════════════════════
# Consumed by: apps/rest, apps/graphql, apps/trpc (src/config/auth.ts)
# Loaded via:  dotenv-cli → turbo → tsx → process.env

# Environment mode. Controls security strictness.
# Values: dev (default), staging, prod
# In dev: uses insecure JWT default, relaxed CORS, optional CSRF
# In prod/staging: JWT_SECRET is required, strict CORS
#ENV=dev

# JWT signing secret. Must be ≥32 characters.
# Required in staging and prod. Optional in dev (uses insecure default with warning).
#JWT_SECRET=your-secret-at-least-32-characters-long

# JWT claim overrides (optional, have sensible defaults)
#JWT_ISSUER=octant-api
#JWT_AUDIENCE=octant-client

# CORS origins (comma-separated). Defaults vary by ENV.
#CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Disable CSRF protection in dev (optional)
#CSRF_DISABLED=true

# Log level for pino logger (optional)
#LOG_LEVEL=debug


# ═════════════════════════════════════════════════════════════════════════════
# FRONTEND API URLs (Vite — VITE_ prefix required, browser-side)
# ═════════════════════════════════════════════════════════════════════════════
# Consumed by: frontend apps via import.meta.env (inlined at build time)
# Loaded via:  dotenv-cli → turbo → Vite process

# RPC endpoint for mainnet chain (ID 1). Used by wagmi for contract reads.
# Dev: http://127.0.0.1:8545 (local anvil)
# Staging: Tenderly Virtual TestNet RPC (see TENDERLY_RPC_URL below)
#VITE_MAINNET_RPC_URL=http://127.0.0.1:8545

# Subgraph GraphQL endpoint. Defaults to local Graph Node if not set.
#VITE_SUBGRAPH_URL=http://localhost:8000/subgraphs/name/octant-token

# GraphQL API endpoint for admin dashboard.
VITE_GRAPHQL_URL=http://localhost:4001/graphql


# ═════════════════════════════════════════════════════════════════════════════
# SUBGRAPH / GRAPH NODE
# ═════════════════════════════════════════════════════════════════════════════
# Consumed by: apps/subgraph/docker-compose.yml and apps/subgraph/scripts/dev.sh
# Loaded via:  dotenv-cli → turbo → shell script (inherits process.env)

# Override Graph Node's Ethereum RPC connection.
# Format: "network_name:rpc_url"
# Default (when unset): localhost:http://host.docker.internal:8545
#
# The network name ("localhost") must match subgraph.yaml's network field.
# For staging, use the same "localhost:" prefix even though the RPC is remote:
#GRAPH_ETHEREUM_RPC=localhost:https://virtual.mainnet.rpc.tenderly.co/YOUR_VIRTUAL_TESTNET_ID


# ═════════════════════════════════════════════════════════════════════════════
# TENDERLY (staging only)
# ═════════════════════════════════════════════════════════════════════════════
# Consumed by: packages/chain/scripts/staging.sh (deploy to Virtual TestNet)
# Loaded via:  dotenv -e .env.staging → pnpm chain:staging
#
# Create a Virtual TestNet at https://dashboard.tenderly.co (fork mainnet, chain ID = 1).
# The RPC URL must appear 3 times in .env.staging (dotenv-cli doesn't interpolate):
#   TENDERLY_RPC_URL          — used by chain:staging deploy script
#   VITE_MAINNET_RPC_URL      — used by web app (wagmi mainnet transport)
#   GRAPH_ETHEREUM_RPC         — used by Graph Node (subgraph indexing)
#
#TENDERLY_RPC_URL=https://virtual.mainnet.rpc.tenderly.co/YOUR_VIRTUAL_TESTNET_ID


# ═════════════════════════════════════════════════════════════════════════════
# RPC URL
# ═════════════════════════════════════════════════════════════════════════════
# Consumed by: packages/vote-blob E2E tests, any package needing an RPC endpoint
# Loaded via:  vitest process.env, dotenv-cli
#
# RPC endpoint for E2E tests and on-chain interactions.
# Set to local Anvil or a Tenderly Virtual TestNet RPC.
#RPC_URL=http://127.0.0.1:8545


# ═════════════════════════════════════════════════════════════════════════════
# THIRD-PARTY APIs (optional)
# ═════════════════════════════════════════════════════════════════════════════

# OpenWeatherMap API key for GraphQL weather query demo
#OPENWEATHERMAP_API_KEY=


# ═════════════════════════════════════════════════════════════════════════════
# PACKAGE → ENV VAR QUICK REFERENCE
# ═════════════════════════════════════════════════════════════════════════════
#
# Package / App            | Env Vars                              | Dev Script
# ─────────────────────────|───────────────────────────────────────|──────────────
# packages/db              | DATABASE_URL                          | (library)
# packages/db-postgres     | POSTGRES_URL                          | (library)
# packages/chain           | ANVIL_PORT, TENDERLY_RPC_URL          | scripts/dev.sh, scripts/staging.sh
# packages/web3            | (none — configured via props)         | (library)
# packages/subgraph-client | (none — configured via setSubgraphUrl)| (library)
# apps/rest                | REST_PORT, POSTGRES_URL, JWT_*, ENV   | tsx watch
# apps/graphql             | GRAPHQL_PORT, DATABASE_URL, JWT_*, ENV| tsx watch
# apps/trpc                | TRPC_PORT, DATABASE_URL, JWT_*, ENV   | tsx watch
# apps/web                 | WEB_PORT, VITE_MAINNET_RPC_URL, VITE_SUBGRAPH_URL | vite
# apps/admin               | ADMIN_PORT, VITE_GRAPHQL_URL          | vite
# apps/widget              | WIDGET_PORT, REST_PORT                | vite
# apps/qf-simulator        | QF_SIMULATOR_PORT, REST_PORT          | vite
# apps/subgraph            | GRAPH_NODE_*, GRAPH_IPFS_PORT, GRAPH_ETHEREUM_RPC, ANVIL_PORT | scripts/dev.sh
# packages/vote-blob       | RPC_URL                                | vitest (E2E)
#
# Shell scripts: packages/chain/scripts/dev.sh, apps/subgraph/scripts/dev.sh
# Both inherit process.env from turbo.
