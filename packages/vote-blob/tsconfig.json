{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": "./src",
    "paths": {
      "@signing/*": ["./signing/*"],
      "@serialization/*": ["./serialization/*"],
      "@storage/*": ["./storage/*"],
      "@merkle/*": ["./merkle/*"],
      "@batch/*": ["./batch/*"],
      "@math/*": ["./math/*"]
    }
  },
  "references": [{ "path": "../vote-types" }],
  "include": ["src/**/*"]
}
