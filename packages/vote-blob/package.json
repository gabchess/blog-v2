{
  "name": "@octant/vote-blob",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "typecheck": "tsc --build tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo"
  },
  "dependencies": {
    "@octant/vote-types": "workspace:*",
    "@openzeppelin/merkle-tree": "^1.0.7"
  },
  "peerDependencies": {
    "viem": ">=2.21.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.9",
    "fast-check": "^3.22.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.2",
    "viem": "^2.21.0",
    "vitest": "^2.1.8"
  }
}
