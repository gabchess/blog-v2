{
  "name": "@octant/db",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc --build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "typecheck": "tsc --build",
    "clean": "rm -rf dist generated .turbo tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@prisma/client": "6.19.2"
  },
  "devDependencies": {
    "@pothos/plugin-prisma": "^4.3.0",
    "@types/node": "^22.10.2",
    "prisma": "6.19.2",
    "prisma-zod-generator": "1.31.8",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "comments": {
      "prisma": "PINNED: Prisma 7.x does not support MongoDB yet. Do not upgrade until MongoDB support is added.",
      "prisma-zod-generator": "PINNED: v1.31.8 is last version compatible with Prisma 6.x. v2.x requires Prisma 7."
    }
  }
}
